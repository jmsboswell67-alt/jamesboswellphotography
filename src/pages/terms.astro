    color: var(--color-text-light);
    margin-top: 0.5rem;
    margin-bottom: 3rem;
  }

  .legal__content h2 {
    font-size: 1.25rem;
    font-weight: 500;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

