    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
    max-width: 75ch;
  }

  .legal__content ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .legal__content li {
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 0.25rem;
  }

  .legal__content a {
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-accent);
