---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="James Boswell Photography">
  <!-- Hero -->
  <section class="hero">
    <img class="hero__bg" src="/photos/hero.jpg" alt="Mountain range at sunset with pink clouds" />
    <div class="hero__overlay"></div>
    <div class="container hero__content">
      <h1 class="hero__title">James Boswell</h1>
      <p class="hero__subtitle">Photography</p>
      <a href="/gallery" class="btn hero__cta">View Gallery</a>
    </div>
  </section>

  <!-- Intro -->
  <section class="section intro">
    <div class="container text-center">
      <h2>Capturing the World Through a Lens</h2>
      <p class="intro__text">
        From the rolling farmlands of the Midwest to the rugged peaks of Colorado,
        from city skylines to intimate wildlife encounters — I chase the light and
        the moments that tell a story worth remembering.
      </p>
    </div>
  </section>

  <!-- Featured Work -->
  <section class="section featured">
    <div class="container">
      <h2 class="text-center">Featured Work</h2>
      <div class="featured__grid">
        <a href="/gallery" class="featured__item featured__item--tall">
          <img src="/photos/IMG_8023-2.jpg" alt="Royal Gorge Bridge at sunset" loading="lazy" />
          <div class="featured__label">Landscape</div>
        </a>
        <a href="/gallery" class="featured__item">
          <img src="/photos/DSCN1029-Enhanced-NR.jpg" alt="Crow portrait from the front" loading="lazy" />
          <div class="featured__label">Wildlife</div>
        </a>
        <a href="/gallery" class="featured__item">
          <img src="/photos/1_1-65.jpg" alt="Man overlooking Chicago skyline in black and white" loading="lazy" />
          <div class="featured__label">Urban</div>
        </a>
        <a href="/gallery" class="featured__item featured__item--wide">
          <img src="/photos/IMG_5853.jpg" alt="Desert lake at dusk" loading="lazy" />
          <div class="featured__label">Nature</div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 3rem;">
        <a href="/gallery" class="btn">Explore Full Gallery</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    height: 85vh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 70%;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.08);
  }

  .hero__content {
    position: relative;
    text-align: center;
    z-index: 1;
  }

  .hero__title {
    font-size: 4rem;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 0.25rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  .hero__subtitle {
    font-size: 1.125rem;
    font-weight: 300;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2.5rem;
  }

  .hero__cta {
    border-color: #fff;
    color: #fff;
  }

  .hero__cta:hover {
    background: #fff;
    color: var(--color-text);
  }

  .intro__text {
    margin: 1.5rem auto 0;
    font-size: 1.0625rem;
    color: var(--color-text-light);
    line-height: 1.8;
    text-align: center;
  }

  .featured h2 {
    margin-bottom: 2.5rem;
  }

  .featured__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 250px;
    gap: 1rem;
  }

  .featured__item {
    position: relative;
    overflow: hidden;
    text-decoration: none;
  }

  .featured__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .featured__item:hover img {
    transform: scale(1.05);
  }

  .featured__label {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(0,0,0,0.5);
    padding: 0.35rem 0.75rem;
    backdrop-filter: blur(4px);
  }

  .featured__item--tall {
    grid-row: span 2;
  }

  .featured__item--wide {
    grid-column: span 2;
  }

  @media (max-width: 768px) {
    .hero {
      height: 70vh;
    }

    .hero__title {
      font-size: 2.25rem;
    }

    .hero__subtitle {
      font-size: 0.875rem;
    }

    .featured__grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 200px;
    }

    .featured__item--tall,
    .featured__item--wide {
      grid-row: span 1;
      grid-column: span 1;
    }
  }
</style>
